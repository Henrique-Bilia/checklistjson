<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/tvWallTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Checklists WALL (WUBR/WDBR)"
        android:textSize="20sp"
        android:paddingBottom="8dp" />

    <Button
        android:id="@+id/btnExportarModeloWall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Exportar modelo WALL em PDF"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnImportarOcrWall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Importar (OCR) - OP/TAG"
        android:layout_marginBottom="8dp" />

    <ListView
        android:id="@+id/listViewWall"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>

