<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvHeaderTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dados do equipamento"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <Button
            android:id="@+id/btnSelecionarMaquina"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecionar máquina"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnImportarOcr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Importar (OCR) - OP/TAG"
            android:layout_marginBottom="12dp" />

        <!-- Linha 1: Elaborado / Data elaboração / Aprovado / Data aprovação -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_margin="1dp"
                android:background="@drawable/bg_header_cell">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Elaborado por"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etElaboradoPor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nome de quem elaborou"
                    android:singleLine="true"
                    android:maxLines="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_margin="1dp"
                android:background="@drawable/bg_header_cell">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Data da elaboração"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etDataElaboracao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="dd/mm/aaaa"
                    android:focusable="false"
                    android:clickable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_margin="1dp"
                android:background="@drawable/bg_header_cell">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aprovado por"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etAprovadoPor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nome de quem aprovou"
                    android:singleLine="true"
                    android:maxLines="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_margin="1dp"
                android:background="@drawable/bg_header_cell">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Data da aprovação"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etDataAprovacao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="dd/mm/aaaa"
                    android:focusable="false"
                    android:clickable="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- Linha 2: Cliente/Obra / Modelo / S/N -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginTop="8dp"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_margin="1dp"
                android:background="@drawable/bg_header_cell">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cliente / Obra"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etClienteObra"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Cliente / Obra" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_margin="1dp"
                android:background="@drawable/bg_header_cell">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Modelo"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etModelo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Modelo" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_margin="1dp"
                android:background="@drawable/bg_header_cell">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="S/N"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etSn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Número de série" />
            </LinearLayout>
        </LinearLayout>

        <!-- Linha 3: Fluído / Tensão / OP / TAG -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            android:layout_marginTop="8dp"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_margin="1dp"
                android:background="@drawable/bg_header_cell">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fluído"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etFluido"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Fluído / Refrigerante" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_margin="1dp"
                android:background="@drawable/bg_header_cell">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tensão"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etTensao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tensão" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_margin="1dp"
                android:background="@drawable/bg_header_cell">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="OP"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etOp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="OP" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_margin="1dp"
                android:background="@drawable/bg_header_cell">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TAG"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etTag"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="TAG" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnContinuarChecklist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Continuar para checklist"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>

